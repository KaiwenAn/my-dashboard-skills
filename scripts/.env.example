# 飞书看板助手 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# === 飞书应用凭证 ===
# 从飞书开放平台 → 应用 → 凭证与基础信息 获取
FEISHU_APP_ID=cli_aa8e93dcd3ba5be9
FEISHU_APP_SECRET=GtcIhRnyVu1YjvLfSfnuMh0eqEhA0VjY

# === 飞书事件订阅验证（可选） ===
# 从飞书开放平台 → 事件订阅 获取
# FEISHU_VERIFICATION_TOKEN=
# FEISHU_ENCRYPT_KEY=

# === Pipeline 配置（可选，有默认值） ===
# 工作空间目录，默认为脚本父目录
# WORKSPACE_DIR=C:\path\to\project

# === LLM 配置（可选，config.json 优先） ===
# HUNYUAN_API_KEY=
# DEEPSEEK_API_KEY=
# LLM_BASE_URL=

# === 数据平台配置（可选，config.json 优先） ===
# DATA_PLATFORM_BASE_URL=
# DATA_PLATFORM_TOKEN=

# === BI 编辑助手 Cookie（必需，启用 copilot 自动建图时） ===
# 从浏览器 DevTools → 任意 BI 平台请求 → 复制 Cookie 整段
# 过期后需重新抓取（约 1 天有效）
# 留空 / 未设置 → Pipeline 仍能跑，但跳过自动建图，降级为只发方案文档
# COPILOT_COOKIE=
